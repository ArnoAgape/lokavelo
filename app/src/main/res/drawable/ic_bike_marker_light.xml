<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cercle blanc avec contour noir -->
    <item
        android:left="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <size
                android:width="40dp"
                android:height="40dp" />
            <solid android:color="#FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#4D497787" />
        </shape>
    </item>

    <!-- Logo décalé vers la droite -->
    <item
        android:width="30dp"
        android:height="30dp"
        android:drawable="@drawable/ic_velo_logo"
        android:gravity="center"
        android:left="3dp" />

</layer-list>
